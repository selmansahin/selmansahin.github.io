---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero-section {
				margin-bottom: 3em;
			}
			.hero-section h1 {
				font-size: 2.4em;
				margin-bottom: 0.5em;
			}
			.recent-posts {
				margin-top: 2em;
			}
			.recent-posts h2 {
				font-size: 1.6em;
				margin-bottom: 1em;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-list li {
				border-bottom: 1px solid rgb(var(--gray-light));
				padding: 1.2em 0;
			}
			.post-list li:last-child {
				border-bottom: none;
			}
			.post-list a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.post-list a:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-size: 1.2em;
				font-weight: 700;
				margin: 0 0 0.3em 0;
				color: rgb(var(--black));
				transition: color 0.2s ease;
			}
			.post-date {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-bottom: 0.3em;
			}
			.post-description {
				color: rgb(var(--gray-dark));
				margin: 0;
				font-size: 0.95em;
			}
			.all-posts-link {
				display: inline-block;
				margin-top: 1.5em;
				font-weight: 700;
				color: var(--accent);
				text-decoration: none;
			}
			.all-posts-link:hover {
				text-decoration: underline;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-section">
				<h1>Merhaba, ben Selman 👋</h1>
				<p>
					20+ yıllık profesyonel yazılım geliştirme kariyerimde .NET, Python, yapay zeka ve veri bilimi
					alanlarında çalıştım. Yazılımın yanı sıra sosyoloji eğitimi aldım — bu da insanı ve toplumu
					anlamaya dair kişisel merakımın bir yansıması.
				</p>
				<p>
					Bu blogda yazılımdan girişimciliğe, veri biliminden hayat derslerine kadar birçok
					konuda düşüncelerimi paylaşıyorum.
				</p>
				<p>
					<strong>İnanıyorum ki en iyi algoritmalar, hayatın kendisinde gizli.</strong>
				</p>
			</section>

			<section class="recent-posts">
				<h2>Son Yazılar</h2>
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<div class="post-title">{post.data.title}</div>
								<div class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</div>
								{post.data.description && (
									<p class="post-description">{post.data.description}</p>
								)}
							</a>
						</li>
					))}
				</ul>
				<a href="/blog" class="all-posts-link">Tüm yazılar →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
