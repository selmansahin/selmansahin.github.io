---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { SITE_TITLE } from '../../../consts';

const posts = (await getCollection('manevi'))
	.filter((post) => post.data.category === 'tefsir')
	.sort((a, b) => (a.data.sira ?? 999) - (b.data.sira ?? 999));
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={`Tefsir | Manevi | ${SITE_TITLE}`} description="Kur'an-ı Kerim surelerinin tefsirleri" />
		<style>
			main {
				width: 960px;
			}
			.page-header {
				text-align: center;
				margin-bottom: 2.5em;
				padding: 2.5em 0 1.5em;
			}
			.breadcrumb {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-bottom: 1.5em;
			}
			.breadcrumb a {
				color: #1a5c2e;
				text-decoration: none;
			}
			.breadcrumb a:hover {
				text-decoration: underline;
			}
			.breadcrumb .sep {
				margin: 0 0.4em;
				color: #c8a95e;
			}
			.page-header h1 {
				font-size: 2.4em;
				background: linear-gradient(135deg, #1a5c2e, #2d8a4e, #1a5c2e);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				margin-bottom: 0.3em;
			}
			.page-header .ornament {
				font-size: 1.6em;
				color: #c8a95e;
				margin-bottom: 0.5em;
			}
			.page-header p {
				color: rgb(var(--gray));
				font-size: 1em;
				max-width: 550px;
				margin: 0 auto;
			}

			/* Search */
			.search-wrapper {
				margin-bottom: 2em;
				position: relative;
				max-width: 480px;
				margin-left: auto;
				margin-right: auto;
			}
			.search-wrapper svg {
				position: absolute;
				left: 14px;
				top: 50%;
				transform: translateY(-50%);
				color: rgb(var(--gray));
				pointer-events: none;
			}
			#tefsir-search {
				width: 100%;
				padding: 0.7em 1em 0.7em 2.6em;
				border: 1.5px solid #e8d9a8;
				border-radius: 999px;
				font-size: 0.95em;
				font-family: inherit;
				background: #fefcf4;
				color: inherit;
				outline: none;
				transition: border-color 0.2s, box-shadow 0.2s;
				box-sizing: border-box;
			}
			#tefsir-search:focus {
				border-color: #c8a95e;
				box-shadow: 0 0 0 3px rgba(200, 169, 94, 0.15);
			}

			/* Grid */
			.post-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
				gap: 1.2em;
			}
			.post-card {
				background: linear-gradient(135deg, #fefcf4, #fff9e6);
				border: 1px solid #e8d9a8;
				border-radius: 14px;
				padding: 1.6em;
				text-decoration: none;
				color: inherit;
				transition: all 0.3s ease;
				display: flex;
				flex-direction: column;
				gap: 0.4em;
				position: relative;
				overflow: hidden;
			}
			.post-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				height: 4px;
				background: linear-gradient(90deg, #c8a95e, #1a5c2e, #c8a95e);
				opacity: 0;
				transition: opacity 0.3s ease;
			}
			.post-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 8px 32px rgba(200, 169, 94, 0.2);
				border-color: #c8a95e;
			}
			.post-card:hover::before {
				opacity: 1;
			}
			.card-top {
				display: flex;
				align-items: center;
				gap: 0.6em;
			}
			.sira-badge {
				font-size: 0.72em;
				font-weight: 600;
				color: #1a5c2e;
				background: rgba(26, 92, 46, 0.08);
				border: 1px solid rgba(26, 92, 46, 0.2);
				border-radius: 999px;
				padding: 0.15em 0.6em;
				white-space: nowrap;
			}
			.post-card h3 {
				font-size: 1.08em;
				color: #1a5c2e;
				margin: 0;
				line-height: 1.4;
			}
			.post-card p {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.5;
				flex: 1;
			}
			.post-card .date {
				font-size: 0.75em;
				color: rgb(var(--gray));
				margin-top: 0.4em;
			}
			.empty-state {
				text-align: center;
				padding: 3em;
				color: rgb(var(--gray));
			}
			.no-results {
				display: none;
				text-align: center;
				padding: 2.5em;
				color: rgb(var(--gray));
			}
			@media (max-width: 720px) {
				.post-grid {
					grid-template-columns: 1fr;
				}
				.page-header h1 {
					font-size: 1.8em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-header">
				<div class="breadcrumb">
					<a href="/">Ana Sayfa</a>
					<span class="sep">›</span>
					<a href="/manevi">Manevi</a>
					<span class="sep">›</span>
					Tefsir
				</div>
				<div class="ornament">📖</div>
				<h1>Tefsir</h1>
				<p>Kur'an-ı Kerim surelerinin tefsirleri ve açıklamaları</p>
			</section>

			<!-- Arama -->
			<div class="search-wrapper">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
				</svg>
				<input
					id="tefsir-search"
					type="search"
					placeholder="Sure adı veya numarası ile ara…"
					autocomplete="off"
				/>
			</div>

			{posts.length > 0 ? (
				<>
					<div class="post-grid" id="tefsir-grid">
						{posts.map((post) => (
							<a href={`/manevi/tefsir/${post.id.replace(/^tefsir\//, '')}/`} class="post-card" data-title={post.data.title.toLowerCase()} data-sira={post.data.sira ?? ''}>
								<div class="card-top">
									{post.data.sira && <span class="sira-badge">{post.data.sira}. Sûre</span>}
									<h3>{post.data.title}</h3>
								</div>
								<p>{post.data.description}</p>
								<div class="date">
									<FormattedDate date={post.data.pubDate} />
								</div>
							</a>
						))}
					</div>
					<div class="no-results" id="no-results">
						<p>Aramanızla eşleşen sûre bulunamadı.</p>
					</div>
				</>
			) : (
				<div class="empty-state">
					<p>Henüz bu kategoride içerik bulunmuyor.</p>
				</div>
			)}
		</main>
		<Footer />

		<script>
			const input = document.getElementById('tefsir-search') as HTMLInputElement;
			const grid = document.getElementById('tefsir-grid');
			const noResults = document.getElementById('no-results');

			if (input && grid) {
				input.addEventListener('input', () => {
					const q = input.value.trim().toLowerCase();
					const cards = grid.querySelectorAll<HTMLAnchorElement>('.post-card');
					let visible = 0;

					cards.forEach((card) => {
						const title = card.dataset.title ?? '';
						const sira = card.dataset.sira ?? '';
						const match = !q || title.includes(q) || sira.includes(q);
						(card as HTMLElement).style.display = match ? '' : 'none';
						if (match) visible++;
					});

					if (noResults) {
						noResults.style.display = visible === 0 ? 'block' : 'none';
					}
				});
			}
		</script>
	</body>
</html>
