---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('kitaplar'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={`Kitaplar | ${SITE_TITLE}`} description="Okuduğum kitaplar hakkında yorumlarım" />
		<style>
			main {
				width: 960px;
			}
			.page-header {
				text-align: center;
				margin-bottom: 3em;
				padding: 2.5em 0 1.5em;
			}
			.page-header .icon {
				font-size: 2.4em;
				margin-bottom: 0.3em;
			}
			.page-header h1 {
				font-size: 2.6em;
				background: linear-gradient(135deg, #92400e, #b45309, #d97706);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				margin-bottom: 0.3em;
			}
			.page-header p {
				color: rgb(var(--gray));
				font-size: 1.05em;
				max-width: 500px;
				margin: 0 auto;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-list li {
				background: white;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 14px;
				padding: 1.6em 2em;
				margin-bottom: 1.2em;
				transition: all 0.3s ease;
			}
			.post-list li:hover {
				transform: translateY(-2px);
				box-shadow: 0 6px 24px rgba(180, 83, 9, 0.1);
				border-color: #b45309;
			}
			.post-list a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.post-list .post-title {
				font-size: 1.3em;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0 0 0.3em 0;
				transition: color 0.2s ease;
			}
			.post-list li:hover .post-title {
				color: #b45309;
			}
			.post-list .post-date {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-bottom: 0.4em;
			}
			.post-list .post-desc {
				color: rgb(var(--gray-dark));
				margin: 0;
				font-size: 0.95em;
				line-height: 1.6;
			}
			.empty-state {
				text-align: center;
				padding: 3em;
				color: rgb(var(--gray));
			}
			.empty-state .empty-icon {
				font-size: 3em;
				margin-bottom: 0.5em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-header">
				<div class="icon">📚</div>
				<h1>Kitaplar</h1>
				<p>Okuduğum kitaplar hakkında yorumlarım ve önerilerim</p>
			</section>

			{posts.length > 0 ? (
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/kitaplar/${post.id}/`}>
								<div class="post-title">{post.data.title}</div>
								<div class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</div>
								{post.data.description && (
									<p class="post-desc">{post.data.description}</p>
								)}
							</a>
						</li>
					))}
				</ul>
			) : (
				<div class="empty-state">
					<div class="empty-icon">📚</div>
					<p>Henüz bu kategoride yazı bulunmuyor.</p>
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
